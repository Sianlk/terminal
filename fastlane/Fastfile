# fastlane/Fastfile
# Generated for Terminal AI — com.sianlk.terminalai

update_fastlane

default_platform(:ios)

APP_IDENTIFIER = "com.sianlk.terminalai"
APP_NAME       = "Terminal AI"
SCHEME         = "terminalai"

platform :ios do
  desc "Run iOS tests"
  lane :test do
    run_tests(
      project:       "ios/App.xcodeproj",
      scheme:        APP_NAME,
      devices:       ["iPhone 16"],
      clean:         true,
      code_coverage: true
    )
  end

  desc "Build and upload to TestFlight (beta)"
  lane :beta do
    ensure_git_status_clean
    match(type: "appstore", app_identifier: APP_IDENTIFIER, readonly: true)
    increment_build_number(xcodeproj: "ios/App.xcodeproj")
    build_app(
      workspace: "ios/App.xcworkspace",
      scheme:    APP_NAME,
      clean:     true,
      output_directory: "./build",
      output_name: "Terminal AI.ipa"
    )
    upload_to_testflight(skip_waiting_for_build_processing: true)
    slack(message: "Terminal AI beta uploaded to TestFlight!") if ENV["SLACK_URL"]
  end

  desc "Submit to App Store"
  lane :release do
    ensure_git_status_clean
    match(type: "appstore", app_identifier: APP_IDENTIFIER, readonly: true)
    increment_build_number(xcodeproj: "ios/App.xcodeproj")
    build_app(workspace: "ios/App.xcworkspace", scheme: APP_NAME, clean: true)
    upload_to_app_store(
      app_identifier:    APP_IDENTIFIER,
      skip_screenshots:  false,
      skip_metadata:     false,
      force:             true,
      submit_for_review: false,
      automatic_release: true,
      precheck_include_in_app_purchases: false
    )
    slack(message: "Terminal AI submitted to App Store!") if ENV["SLACK_URL"]
  end
end

platform :android do
  desc "Run Android tests"
  lane :test do
    gradle(task: "test", project_dir: "android/")
  end

  desc "Build and upload AAB to internal track"
  lane :beta do
    ensure_git_status_clean
    gradle(
      task: "bundle", build_type: "Release", project_dir: "android/",
      properties: {
        "android.injected.signing.store.file"     => ENV["ANDROID_KEYSTORE_FILE"],
        "android.injected.signing.store.password" => ENV["ANDROID_KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["ANDROID_KEY_ALIAS"],
        "android.injected.signing.key.password"   => ENV["ANDROID_KEY_PASSWORD"]
      }
    )
    upload_to_play_store(
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["GOOGLE_PLAY_JSON_KEY"],
      release_status: "completed"
    )
  end

  desc "Promote internal to production"
  lane :release do
    upload_to_play_store(
      track: "internal", track_promote_to: "production",
      json_key_data: ENV["GOOGLE_PLAY_JSON_KEY"], rollout: "0.1"
    )
  end
end
