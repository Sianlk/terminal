# ============================================================
# Terminal AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# API
EXPO_PUBLIC_API_URL=https://api.terminal.app

# Sentry (error monitoring)
EXPO_PUBLIC_SENTRY_DSN=

# Analytics
EXPO_PUBLIC_ANALYTICS_KEY=

# ── Backend (.env for FastAPI) ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/terminal
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=CHANGE_ME_to_a_64_char_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Sentry (backend)
SENTRY_DSN=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_PRIVATE_KEY=
APPLE_KEY_ID=
APPLE_TEAM_ID=

# Push notifications (FCM)
FCM_SERVER_KEY=

# Email (for password reset)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
FROM_EMAIL=noreply@sianlk.com
