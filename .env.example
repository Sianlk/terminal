# ─────────────────────────────────────────────────────────────
# Terminal AI — Environment Configuration Template
# Copy to .env and fill in your values. NEVER commit .env!
# See .github/SECRETS_SETUP.md for GitHub Secrets setup.
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
APP_NAME=Terminal AI
APP_ENV=development
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
BRAND_COLOR=#111827

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/terminal_ai_dev
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_ID_PRO=price_REPLACE_ME
STRIPE_PRICE_ID_ENTERPRISE=price_REPLACE_ME

# ── OAuth2 ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_ME
APPLE_CLIENT_ID=com.sianlk.terminalai
APPLE_TEAM_ID=REPLACE_ME
APPLE_KEY_ID=REPLACE_ME
APPLE_PRIVATE_KEY_PATH=./apple_auth_key.p8

# ── Email (SMTP) ──────────────────────────────────────────────
EMAIL_FROM=noreply@sianlk.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME

# ── Push Notifications (Firebase) ────────────────────────────
FIREBASE_SERVER_KEY=REPLACE_ME
FCM_PROJECT_ID=REPLACE_ME

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=https://REPLACE_ME@sentry.io/REPLACE_ME
OTLP_ENDPOINT=http://localhost:4317

# ── CORS ──────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","https://terminal-ai.sianlk.com"]

# ── Docker / K8s ports ────────────────────────────────────────
PORT=8000
GUNICORN_WORKERS=4
LOG_LEVEL=info
