# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.py   text eol=lf
*.sh   text eol=lf
*.css  text eol=lf
*.html text eol=lf

# Declare files that will always have CRLF
*.bat  text eol=crlf

# Declare binary files
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.gz   binary
*.ttf  binary
*.woff binary
*.woff2 binary
*.eot  binary
*.pdf  binary
